async function generateAdaptivePrompt(writingType,focusArea){
  if(!hasAIKey()){alert('Please set your API key in the Parent Dashboard first.');return;}
  let wt=WRITING_TYPES[writingType];let s=S.english.writing;
  let lvNames={1:'beginner (Year 5-6)',2:'intermediate (Year 7-8)',3:'advanced (Year 8-9)'};
  let SC=document.getElementById('SC');
  SC.innerHTML='<div class="cd" style="text-align:center"><h2>Creating a personalised writing exercise...</h2><div class="ds">The AI is designing a '+wt.name.toLowerCase()+' assignment that focuses on: <strong>'+focusArea+'</strong></div><div class="pb"><div class="pf" style="width:50%"></div></div></div>';
  let aiP='Create a writing assignment for a '+lvNames[s.lv]+' student (age 10-11, learns best with clear structured instructions). They need to practise: "'+focusArea+'". Create a '+wt.name+' assignment with clear step-by-step instructions.\nReturn ONLY JSON: {"title":"<title>","inst":"<2-3 sentence instructions>","sc":[{"l":"<step>","h":"<hint>"}],"min":<word count: 30/60/100>,"focus_reminder":"<1-sentence reminder about the skill>"}';
  try{
    let text=await callAI(aiP,1000);
