function selectWritingType(typeKey){
  window._writingType=typeKey;
  let wt=WRITING_TYPES[typeKey];
  let s=S.english.writing;
  let lv=String(s.lv);
  let prompts=wt.prompts[lv]||wt.prompts['3']||wt.prompts['2']||wt.prompts['1']||[];
  let promptCards=prompts.map(function(p){
    let done=s.sn.includes(p.id);
    return '<div class="sc" onclick="startWritingAssignment(\''+typeKey+'\',\''+p.id+'\')" style="border-left:4px solid '+wt.color+';'+(done?'opacity:0.7':'')+'"><h3>'+p.title+'</h3><div class="ds">'+p.inst.substring(0,80)+'...</div>'+(done?'<span class="badge b1">Completed</span>':'<span class="badge b2">Not started</span>')+'</div>';
  }).join('');
  let aiCard=hasAIKey()?'<div class="sc" onclick="generateAIWritingPrompt(\''+typeKey+'\')" style="border-left:4px solid var(--w);background:var(--wl)"><h3>AI-Generated Prompt</h3><div class="ds">Get a fresh writing prompt tailored to areas you need to practise</div><span class="badge b3">AI Powered</span></div>':'';
  let SC=document.getElementById('SC');
