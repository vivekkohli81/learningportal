function startShowYourWork(subj,topic){
  var sywKey=subj+'_'+topic;
  var s=S[subj][topic];
  var lv=String(s.lv);
  var bank=SYW[sywKey]&&SYW[sywKey][lv]?SYW[sywKey][lv]:[];
  if(bank.length===0){
    // Try AI generation if no bank questions
    if(hasAIKey()){generateSYW(subj,topic);return;}
    alert('No show-your-work questions available for this topic and level.');return;
  }
  // Pick a random question
  var q=bank[Math.floor(Math.random()*bank.length)];
  CQ={active:true,subject:subj,topic:topic,mode:'syw',sywQuestion:q,idx:0,score:0,questions:[],answers:[]};
  renderSYWQuestion();
}

