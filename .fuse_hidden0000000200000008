function ib7Card(subj,topic,title,desc,color){
  var s=currentUser.kid.progress.ib7[topic]||{lv:1,ok:0,no:0};
  var pct=s.ok+s.no>0?Math.round(s.ok/(s.ok+s.no)*100):0;
  var h='<div style="background:var(--card);border-radius:12px;padding:14px;border-left:4px solid '+color+'">';
  h+='<h3 style="margin:0 0 4px;color:'+color+';font-size:0.95em">'+title+'</h3>';
  h+='<p style="margin:0 0 6px;font-size:0.8em;color:var(--muted)">'+desc+'</p>';
  h+='<div style="display:flex;gap:6px;font-size:0.75em;margin-bottom:6px;flex-wrap:wrap">';
  h+='<span style="background:'+color+'22;color:'+color+';padding:2px 6px;border-radius:8px">Lv '+s.lv+'</span>';
  h+='<span style="background:#4CAF5022;color:#4CAF50;padding:2px 6px;border-radius:8px">'+pct+'%</span>';
  h+='</div>';
  h+='<div style="display:flex;gap:4px;flex-wrap:wrap">';
  h+='<button onclick="startQuiz(\''+subj+'\',\''+topic+'\')" style="padding:4px 10px;border:none;border-radius:6px;background:'+color+';color:#fff;cursor:pointer;font-size:0.8em">Practice</button>';
  h+='<button onclick="startAIQuiz(\''+subj+'\',\''+topic+'\')" style="padding:4px 10px;border:none;border-radius:6px;background:'+color+'cc;color:#fff;cursor:pointer;font-size:0.8em">AI Quiz</button>';
  h+='<button onclick="showSYW(\''+subj+'\',\''+topic+'\')" style="padding:4px 10px;border:none;border-radius:6px;background:'+color+'99;color:#fff;cursor:pointer;font-size:0.8em">Show Work</button>';
  h+='<button onclick="showIB7Videos(\''+topic+'\')" style="padding:4px 10px;border:none;border-radius:6px;background:'+color+'66;color:#fff;cursor:pointer;font-size:0.8em">Videos</button>';
  h+='</div></div>';
  return h;
}

