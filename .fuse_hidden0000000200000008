function markActive(){
  let d=new Date().toDateString();
  if(S.lastDate===d)return;
  if(S.lastDate){let l=new Date(S.lastDate),n=new Date(d);let diff=Math.floor((n-l)/(86400000));S.streak=diff===1?S.streak+1:1;}
  else S.streak=1;
  S.lastDate=d;sv();
}

function updateHeader(){
  let el1=document.getElementById('s1'),el2=document.getElementById('s2'),el3=document.getElementById('s3');
  if(el1)el1.textContent='Streak: '+(S.streak||0);
  if(el2)el2.textContent='Done: '+(S.total||0);
  if(el3)el3.textContent='Today: '+(S.lastDate||'-');
}

