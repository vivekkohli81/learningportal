function doAddKid(){
  let name=document.getElementById('newName').value.trim();
  let user=document.getElementById('newUser').value.trim().toLowerCase();
  let pass=document.getElementById('newPass').value;
  let age=parseInt(document.getElementById('newAge').value)||11;
  let year=parseInt(document.getElementById('newYear').value)||6;
  let asd=document.getElementById('newAsd').value==='true';
  let color=document.getElementById('newColor').value||AVATAR_COLORS[0];
  let err=document.getElementById('addErr');

  if(!name||!user||!pass){err.textContent='Please fill in name, username, and password.';return;}
  if(user.length<3){err.textContent='Username must be at least 3 characters.';return;}
  if(pass.length<4){err.textContent='Password must be at least 4 characters.';return;}
  if(user==='admin'){err.textContent='Username "admin" is reserved.';return;}
  if(DB.kids.find(function(k){return k.username.toLowerCase()===user;})){err.textContent='Username "'+user+'" already exists. Choose a different one.';return;}
  if(DB.kids.length>=100){err.textContent='Maximum 100 students reached.';return;}

  let kid={
    id:'kid_'+Date.now(),
    username:user,
    password:pass,
    name:name,
    age:age,
    year:year,
    asd:asd,
    avatarColor:color,
    progress:defaultKidProgress()
  };
  DB.kids.push(kid);
  saveDB(DB);
  adminTab('students');
}

function editKid(idx){
  let k=DB.kids[idx];
  if(!k)return;
  let SC=document.getElementById('SC');
  let colorOpts=AVATAR_COLORS.map(function(c){
    let sel=c===k.avatarColor?'outline:3px solid var(--t)':'';
    return `<div onclick="document.querySelectorAll('.color-pick').forEach(d=>d.style.outline='none');this.style.outline='3px solid var(--t)';document.getElementById('editColor').value='${c}';" class="color-pick" style="width:36px;height:36px;border-radius:50%;background:${c};cursor:pointer;display:inline-block;margin:4px;${sel}"></div>`;
  }).join('');
  let subjects={english:{punctuation:'Punctuation',reading:'Reading Comprehension',writing:'Writing'},maths:{geometry:'Geometry',problemSolving:'Problem Solving',number:'Number'},science:{biology:'Biology',chemistry:'Chemistry',physics:'Physics',earthSpace:'Earth & Space'},ib7:{numberAlgebra:'Number & Algebra',fractionDecimal:'Fractions & Decimals',percentage:'Percentage',equations:'Equations',geometry7:'Geometry',measurement:'Measurement',statistics:'Statistics',probability:'Probability'}};
  let levelOpts='';
  for(let subj in subjects){
    levelOpts+=`<h4 style="margin-top:12px;margin-bottom:8px">${subj.charAt(0).toUpperCase()+subj.slice(1)}</h4>`;
    for(let topic in subjects[subj]){
      let curLv=k.progress[subj][topic].lv||1;
      levelOpts+=`<div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0"><span>${subjects[subj][topic]}</span><select id="lv_${subj}_${topic}" style="padding:4px 8px;border:1px solid var(--b);border-radius:6px"><option value="1"${curLv===1?' selected':''}>Level 1 - Beginner</option><option value="2"${curLv===2?' selected':''}>Level 2 - Intermediate</option><option value="3"${curLv===3?' selected':''}>Level 3 - Advanced</option><option value="4"${curLv===4?' selected':''}>Level 4 - Expert</option><option value="5"${curLv===5?' selected':''}>Level 5 - Master</option></select></div>`;
    }
  }
  let yearOpts=[4,5,6,7,8,9,10].map(function(y){return `<option value="${y}"${k.year==y?' selected':''}>Year ${y}</option>`;}).join('');
  SC.innerHTML=`<div class="cd"><h3>Edit Student: ${k.name}</h3>
    <div class="form-group"><label>Full Name</label><input type="text" id="editName" value="${k.name}"></div>
    <div class="form-group"><label>Username</label><input type="text" id="editUser" value="${k.username}"></div>
    <div class="form-group"><label>Age</label><input type="number" id="editAge" value="${k.age}" min="5" max="18"></div>
    <div class="form-group"><label>School Year</label><select id="editYear">${yearOpts}</select></div>
    <div class="form-group"><label>Clear language mode</label><select id="editAsd"><option value="true"${k.asd?' selected':''}>Yes - Use clear, structured language</option><option value="false"${!k.asd?' selected':''}>No - Standard mode</option></select></div>
    <div class="form-group"><label>Avatar Colour</label><div style="display:flex;flex-wrap:wrap;gap:4px">${colorOpts}</div><input type="hidden" id="editColor" value="${k.avatarColor}"></div>
    <div class="cd" style="margin-top:16px"><h3>Topic Levels</h3><div class="ds">Adjust the difficulty level for each topic.</div>${levelOpts}</div>
    <div class="login-err" id="editErr"></div>
    <div style="margin-top:16px;display:flex;gap:8px"><button class="bt bp" onclick="doEditKid(${idx})">Save Changes</button><button class="bt" style="background:var(--b)" onclick="adminTab('students')">Cancel</button></div></div>`;
}
function doEditKid(idx){
  let k=DB.kids[idx];
  if(!k)return;
  let name=document.getElementById('editName').value.trim();
  let user=document.getElementById('editUser').value.trim().toLowerCase();
  let age=parseInt(document.getElementById('editAge').value)||11;
  let year=parseInt(document.getElementById('editYear').value)||6;
  let asd=document.getElementById('editAsd').value==='true';
  let color=document.getElementById('editColor').value||k.avatarColor;
  let err=document.getElementById('editErr');

  if(!name||!user){err.textContent='Name and username are required.';return;}
  if(user==='admin'){err.textContent='Username "admin" is reserved.';return;}
  let dup=DB.kids.find(function(kk,i){return i!==idx&&kk.username.toLowerCase()===user;});
  if(dup){err.textContent='Username "'+user+'" is already taken.';return;}

  k.name=name;k.username=user;k.age=age;k.year=year;k.asd=asd;k.avatarColor=color;

  // Update levels
  let subjects={english:['punctuation','reading','writing'],maths:['geometry','problemSolving','number']};
  for(let subj in subjects){
    subjects[subj].forEach(function(topic){
      let sel=document.getElementById('lv_'+subj+'_'+topic);
      if(sel) k.progress[subj][topic].lv=parseInt(sel.value)||1;
    });
  }

  saveDB(DB);
  adminTab('students');
}

function resetKidPassword(idx){
  let k=DB.kids[idx];
  if(!k)return;
  let newPass=prompt('Enter new password for '+k.name+':');
  if(!newPass||newPass.length<4){alert('Password must be at least 4 characters.');return;}
  k.password=newPass;
  saveDB(DB);
  alert('Password updated for '+k.name+'.');
}

function deleteKid(idx){
  let k=DB.kids[idx];
  if(!k)return;
  if(!confirm('Delete student "'+k.name+'"? This will remove ALL their progress permanently. This cannot be undone.'))return;
  DB.kids.splice(idx,1);
  saveDB(DB);
  adminTab('students');
}

// === PROGRESS OVERVIEW ===
function renderAdminProgress(el){
  if(DB.kids.length===0){
    el.innerHTML='<div class="cd"><div class="empty"><h3>No students yet</h3><div class="ds">Add students first to see their progress.</div></div></div>';
    return;
  }

  // Kid selector
  let kidPicker='<div class="form-group"><label>Select Student</label><select class="api" id="progressKid" onchange="renderKidProgress()" style="padding:10px">';
  kidPicker+='<option value="all">All Students - Overview</option>';
  DB.kids.forEach(function(k,i){kidPicker+='<option value="'+i+'">'+k.name+'</option>';});
  kidPicker+='</select></div>';

  el.innerHTML='<div class="cd"><h3>Progress Tracking</h3><div class="ds">View detailed progress for each student.</div>'+kidPicker+'</div><div id="progressDetail"></div>';
  renderKidProgress();
}

function renderKidProgress(){
  let sel=document.getElementById('progressKid');
  let detail=document.getElementById('progressDetail');
  if(!sel||!detail)return;

  if(sel.value==='all'){
    // Overview of all kids
    let rows=DB.kids.map(function(k){
      let p=k.progress;
      let totalRight=0,totalWrong=0;
      ['english','maths'].forEach(function(subj){
        Object.keys(p[subj]).forEach(function(t){totalRight+=p[subj][t].ok;totalWrong+=p[subj][t].no;});
      });
      let pct=totalRight+totalWrong>0?Math.round(totalRight/(totalRight+totalWrong)*100):0;
      let writings=p.wr?p.wr.length:0;
      return '<tr><td><div style="display:flex;align-items:center;gap:8px"><div class="kid-avatar" style="background:'+k.avatarColor+';width:32px;height:32px;font-size:14px">'+k.name.charAt(0)+'</div>'+k.name+'</div></td><td>'+p.streak+'</td><td>'+p.total+'</td><td>'+pct+'%</td><td>'+writings+'</td><td>'+(p.lastDate||'Never')+'</td></tr>';
    }).join('');
    detail.innerHTML='<div class="cd"><table class="tb"><tr><th>Student</th><th>Streak</th><th>Completed</th><th>Accuracy</th><th>Writings</th><th>Last Active</th></tr>'+rows+'</table></div>';
    return;
  }

  // Individual kid detail
  let idx=parseInt(sel.value);
  let k=DB.kids[idx];
  if(!k){detail.innerHTML='';return;}
  let p=k.progress;

  let lvBadgeF=function(lv){let labels=['','Beginner','Intermediate','Advanced','Expert','Master'];let cls=['','b2','b3','b1','b3','b3'];return '<span class="badge '+(cls[lv]||'b2')+'">Level '+lv+' - '+(labels[lv]||'Unknown')+'</span>';};
  let pctBarF=function(ok,no){let t=ok+no;let pct=t>0?Math.round(ok/t*100):0;return '<div class="pb"><div class="pf" style="width:'+pct+'%"></div></div><div style="font-size:12px;color:var(--t2)">'+ok+' correct, '+no+' incorrect ('+pct+'%)</div>';};

  let subjects={english:{punctuation:'Punctuation',reading:'Reading Comprehension',writing:'Writing'},maths:{geometry:'Geometry',problemSolving:'Problem Solving',number:'Number'},science:{biology:'Biology',chemistry:'Chemistry',physics:'Physics',earthSpace:'Earth & Space'},ib7:{numberAlgebra:'Number & Algebra',fractionDecimal:'Fractions & Decimals',percentage:'Percentage',equations:'Equations',geometry7:'Geometry',measurement:'Measurement',statistics:'Statistics',probability:'Probability'}};
  let html='';
  for(let subj in subjects){
    html+='<div class="cd"><h3>'+subj.charAt(0).toUpperCase()+subj.slice(1)+'</h3>';
    for(let topic in subjects[subj]){
      let d=p[subj][topic];
      html+='<div style="margin-bottom:16px"><strong>'+subjects[subj][topic]+'</strong> '+lvBadgeF(d.lv)+pctBarF(d.ok,d.no);
      if(d.h&&d.h.length>0){
        html+='<div style="margin-top:8px;font-size:13px"><strong>Recent:</strong> '+d.h.slice(-3).map(function(h){return h.date+': '+h.score+'/'+h.total;}).join(' | ')+'</div>';
      }
      html+='</div>';
    }
    html+='</div>';
  }

  // Writing submissions
  if(p.wr&&p.wr.length>0){
    html+='<div class="cd"><h3>Writing Submissions ('+p.wr.length+')</h3>';
    p.wr.slice().reverse().slice(0,5).forEach(function(w){
      let modeLabel=w.mode==='ai'?'<span class="badge b3">AI Reviewed</span>':'<span class="badge b2">Quick Check</span>';
      let scoreColor=w.score>=75?'b1':w.score>=50?'b2':'b3';
      html+='<div style="padding:12px;background:#f8fafc;border-radius:var(--r);margin-bottom:8px;border:1px solid var(--b)"><div style="display:flex;justify-content:space-between;align-items:center"><strong>'+w.title+'</strong> <span class="badge '+scoreColor+'">'+w.score+'/100</span></div><div style="font-size:12px;color:var(--t2);margin-top:4px">'+w.date+' | '+(w.type||'Writing')+' '+modeLabel+'</div>';
      if(w.mode==='ai'&&w.aiFeedback&&w.aiFeedback.next_focus){
        html+='<div style="font-size:12px;margin-top:4px;color:var(--w)">Next focus: '+w.aiFeedback.next_focus+'</div>';
      }
      html+='</div>';
    });
    html+='</div>';
  }

  detail.innerHTML=html;
}
