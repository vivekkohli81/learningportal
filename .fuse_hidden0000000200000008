}

function startWritingAssignment(typeKey,promptId){
  let wt=WRITING_TYPES[typeKey];
  let s=S.english.writing;
  let lv=String(s.lv);
  let prompts=wt.prompts[lv]||wt.prompts['3']||wt.prompts['2']||wt.prompts['1']||[];
  let p=prompts.find(function(x){return x.id===promptId;});
  if(!p){alert('Prompt not found.');return;}
