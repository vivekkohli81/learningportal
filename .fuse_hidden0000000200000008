// === QUIZ ENGINE ===
function startQuiz(subj,topic){
  let s=S[subj][topic];
  let lv=String(s.lv);
  let bank;
  if(subj==='english'){
    if(topic==='punctuation') bank=PQ[lv]||[];
    else if(topic==='reading'){startReading(subj,topic);return;}
    else if(topic==='writing'){startWriting(subj,topic);return;}
    else bank=[];
  } else if(subj==='maths'){
    if(topic==='geometry') bank=GQ[lv]||[];
    else if(topic==='problemSolving') bank=PS[lv]||[];
    else if(topic==='number') bank=NQ[lv]||[];
    else bank=[];
  } else if(subj==='ib7'){
    if(topic==='wholeNumbers') bank=MYP_CH1[lv]||[];
    else if(topic==='numberProperties') bank=MYP_CH2[lv]||[];
    else if(topic==='linesAngles') bank=MYP_CH3[lv]||[];
    else if(topic==='numberStrategies') bank=MYP_CH4[lv]||[];
    else if(topic==='posNegNumbers') bank=MYP_CH5[lv]||[];
    else if(topic==='fractions') bank=MYP_CH6[lv]||[];
    else if(topic==='decimals') bank=MYP_CH7[lv]||[];
    else if(topic==='algebra') bank=MYP_CH8[lv]||[];
    else if(topic==='percentage') bank=MYP_CH9[lv]||[];
    else if(topic==='equations') bank=MYP_CH10[lv]||[];
    else if(topic==='polygons') bank=MYP_CH11[lv]||[];
    else if(topic==='measurementArea') bank=MYP_CH12[lv]||[];
    else if(topic==='solids') bank=MYP_CH13[lv]||[];
    else if(topic==='volumeMass') bank=MYP_CH14[lv]||[];
    else if(topic==='coordGeometry') bank=MYP_CH15[lv]||[];
    else if(topic==='ratioRates') bank=MYP_CH16[lv]||[];
    else if(topic==='probability') bank=MYP_CH17[lv]||[];
    else if(topic==='statistics') bank=MYP_CH18[lv]||[];
    else if(topic==='transformations') bank=MYP_CH19[lv]||[];
    else bank=[];
  } else if(subj==='science'){
    if(topic==='biology') bank=SCI_BIO[lv]||[];
    else if(topic==='chemistry') bank=SCI_CHEM[lv]||[];
    else if(topic==='physics') bank=SCI_PHYS[lv]||[];
    else if(topic==='earthSpace') bank=SCI_EARTH[lv]||[];
    else bank=[];
  } else { bank=[]; }
  // Prioritise unseen questions
  let unseen=bank.filter(q=>!s.sn.includes(q.id));
  let seen=bank.filter(q=>s.sn.includes(q.id));
  let pool=[...unseen,...seen];
  // Pick 5 questions
  let qs=pool.slice(0,Math.min(5,pool.length));
  if(qs.length===0){
    if(hasAIKey()){generateAI(subj,topic);return;}
    alert('No built-in questions for Level '+s.lv+'. Set up an AI key to unlock unlimited questions at higher levels.');return;
  }
  CQ={active:true,subject:subj,topic:topic,questions:qs,idx:0,score:0,answers:[],mode:'mc'};
  renderQuizQuestion();
}

function renderQuizQuestion(){
  if(!CQ.active)return;
  let SC=document.getElementById('SC');
  let q=CQ.questions[CQ.idx];
  let isGeo=CQ.subject==='maths'&&CQ.topic==='geometry';
  let isSci=CQ.subject==='science';
  SC.innerHTML=`
  <div class="cd">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
      <div class="qn">Question ${CQ.idx+1} of ${CQ.questions.length}</div>
      <div style="font-size:13px;color:var(--t2)">Score: ${CQ.score}/${CQ.idx}</div>
    </div>
    <div class="pb"><div class="pf" style="width:${(CQ.idx/CQ.questions.length)*100}%"></div></div>
  </div>
  <div class="qb">
    <div class="qn">${q.inst}</div>
    ${isGeo&&q.shape?drawShape(q.shape):''}${isSci&&q.shape?'<div id="sciDiag_'+CQ.idx+'" style="max-width:320px;margin:10px auto"></div>':''}
    <div class="qt">${q.txt}</div>
    <div id="opts">
      ${q.opts.map((o,i)=>`<button class="ob" onclick="selectOption(${i})">${o}</button>`).join('')}
    </div>
    <div id="fb"></div>
    <div id="nx" style="margin-top:12px"></div>
  </div>`;
  if(isSci&&q.shape){setTimeout(function(){drawScienceShape('sciDiag_'+CQ.idx,q.shape);},50);}
}

function selectOption(idx){
  if(document.querySelector('.ob.ok')||document.querySelector('.ob.no'))return;
  let q=CQ.questions[CQ.idx];
  let btns=document.querySelectorAll('.ob');
  btns.forEach((b,i)=>{
    if(i===q.cor)b.classList.add('ok');
    if(i===idx&&i!==q.cor)b.classList.add('no');
    b.onclick=null;
  });
  let correct=idx===q.cor;
  if(correct)CQ.score++;
  CQ.answers.push({q:q.id,chose:idx,correct:correct});
  // Mark as seen
  let s=S[CQ.subject][CQ.topic];
  if(!s.sn.includes(q.id))s.sn.push(q.id);
  document.getElementById('fb').innerHTML=`<div class="fb ${correct?'ok':'no'}">${correct?'Correct! ':'Not quite. '}${q.exp}</div>`;
  let isLast=CQ.idx>=CQ.questions.length-1;
  document.getElementById('nx').innerHTML=`<button class="bt bp" onclick="${isLast?'showQuizResults()':'nextQuestion()'}">${isLast?'See Results':'Next Question'}</button>`;
}

function nextQuestion(){
  CQ.idx++;
  renderQuizQuestion();
}

function showQuizResults(){
  let pct=Math.round(CQ.score/CQ.questions.length*100);
  let s=S[CQ.subject][CQ.topic];
  s.ok+=CQ.score;
  s.no+=(CQ.questions.length-CQ.score);
  s.h.push({date:new Date().toDateString(),score:CQ.score,total:CQ.questions.length,pct:pct});
  // Adaptive difficulty
  let lvMsg='';
  if(pct>=80&&s.lv<5){s.lv++;lvMsg='Great work! You have moved up to Level '+s.lv+'.';}
  else if(pct<40&&s.lv>1){s.lv--;lvMsg='Let us practise more at Level '+s.lv+' to build confidence.';}
  else{lvMsg='You are staying at Level '+s.lv+'. Keep practising!';}
  S.total++;
  S.done.push({date:new Date().toDateString(),subject:CQ.subject,topic:CQ.topic,score:CQ.score+'/'+CQ.questions.length});
  markActive();sv();
  let SC=document.getElementById('SC');
  SC.innerHTML=`
  <div class="cd" style="text-align:center">
    <h2>${pct>=80?'Excellent!':pct>=60?'Good effort!':'Keep trying!'}</h2>
    <div style="font-size:48px;font-weight:700;color:${pct>=80?'var(--g)':pct>=60?'var(--w)':'var(--e)'};margin:16px 0">${pct}%</div>
    <div class="ds">You got ${CQ.score} out of ${CQ.questions.length} correct.</div>
    <div style="margin:16px 0;padding:12px;background:var(--pl);border-radius:var(--r);font-size:14px">${lvMsg}</div>
    <div style="margin:16px 0">
      ${CQ.answers.map((a,i)=>{let q=CQ.questions[i];return `<div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--b)"><span style="color:${a.correct?'var(--g)':'var(--e)'}">${a.correct?'✓':'✗'}</span><span style="font-size:13px">${q.txt.substring(0,60)}${q.txt.length>60?'...':''}</span></div>`;}).join('')}
    </div>
    <button class="bt bp" onclick="startQuiz('${CQ.subject}','${CQ.topic}')" style="margin-right:8px">Try Again</button>
    ${hasAIKey()?`<button class="bt" onclick="generateAI('${CQ.subject}','${CQ.topic}')" style="background:var(--v);color:#fff;margin-right:8px">Generate AI Questions</button>`:''}
    <button class="bt" onclick="startShowYourWork('${CQ.subject}','${CQ.topic}')" style="background:var(--w);color:#fff;margin-right:8px">Show Your Work</button>
    <button class="bt bg" onclick="go('${CQ.subject}')">Back to ${CQ.subject==='english'?'English':'Maths'}</button>
  </div>`;
  CQ.active=false;
  updateHeader();
}

// === READING ENGINE ===
function startReading(subj,topic){
  let s=S[subj][topic];
  let lv=String(s.lv);
  let bank=RQ[lv]||[];
  let unseen=bank.filter(p=>!s.sn.includes(p.id));
  let seen=bank.filter(p=>s.sn.includes(p.id));
  let pool=[...unseen,...seen];
  if(pool.length===0){
    if(hasAIKey()){generateAI(subj,topic);return;}
    alert('No built-in passages for this level. Set up an AI key to unlock more.');return;
  }
  let passage=pool[0];
  CQ={active:true,subject:subj,topic:topic,questions:passage.qs,idx:0,score:0,answers:[],mode:'reading',passage:passage};
  renderReadingQuestion();
}

