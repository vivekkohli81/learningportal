function topicCard(subj,topic,title,desc,color){
  let s=S[subj][topic];
  let sywKey=subj+'_'+topic;
  let hasSyw=SYW[sywKey]&&SYW[sywKey][String(s.lv)]&&SYW[sywKey][String(s.lv)].length>0;
  let aiBtn=hasAIKey()?`<div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap">
    <button class="bt bp" onclick="event.stopPropagation();startQuiz('${subj}','${topic}')" style="font-size:12px;padding:6px 12px">Practice Questions</button>
    <button class="bt" onclick="event.stopPropagation();generateAI('${subj}','${topic}')" style="font-size:12px;padding:6px 12px;background:var(--v);color:#fff">AI Questions</button>
    ${hasSyw?`<button class="bt" onclick="event.stopPropagation();startShowYourWork('${subj}','${topic}')" style="font-size:12px;padding:6px 12px;background:var(--w);color:#fff">Show Your Work</button>`:''}
  </div>`:`<div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap"><button class="bt bp" onclick="event.stopPropagation();startQuiz('${subj}','${topic}')" style="font-size:12px;padding:6px 12px">Start Practice</button>
    ${hasSyw?`<button class="bt" onclick="event.stopPropagation();startShowYourWork('${subj}','${topic}')" style="font-size:12px;padding:6px 12px;background:var(--w);color:#fff">Show Your Work</button>`:''}</div>`;
  return `<div class="sc" style="border-left:4px solid ${color};cursor:default">
    <h3>${title}</h3>
    <div class="ds">${desc}</div>
    ${lvBadge(s.lv)}
    ${pctBar(s.ok,s.no)}
    ${aiBtn}
  </div>`;
}

