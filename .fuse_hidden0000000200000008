  SC.innerHTML='<div class="cd" style="text-align:center"><h2>AI Teacher Feedback</h2><div style="font-size:56px;font-weight:700;color:'+scoreColor+';margin:16px 0">'+fb.overall_score+'/100</div><div style="background:var(--pl);padding:16px;border-radius:var(--r);font-size:15px;margin:12px 0">'+(fb.encouragement||'Well done for completing this writing!')+'</div></div><div class="cd"><h3>Scores by Area</h3>'+scoreHtml+'</div><div class="cd"><h3 style="color:var(--g)">What You Did Well</h3>'+strengthsHtml+'</div>'+errorsHtml+'<div class="cd"><h3>Corrected Version</h3><div class="ds">Compare this with what you wrote.</div><div style="background:var(--gl);padding:16px;border-radius:var(--r);border:1px solid var(--g);white-space:pre-wrap;font-size:14px;line-height:1.8;margin-top:8px">'+(fb.corrected_version||originalText).replace(/</g,'&lt;')+'</div></div><div class="cd"><h3>Your Original Writing</h3><div style="background:#f8fafc;padding:16px;border-radius:var(--r);border:1px solid var(--b);white-space:pre-wrap;font-size:14px;line-height:1.8">'+originalText.replace(/</g,'&lt;')+'</div></div><div class="cd"><h3>How to Improve Next Time</h3>'+tipsHtml+'<div style="margin-top:16px;padding:16px;background:var(--wl);border-radius:var(--r);border-left:4px solid var(--w)"><strong>Your next focus area:</strong> '+(fb.next_focus||'Keep practising!')+'</div></div><div style="margin-top:16px;display:flex;gap:8px;flex-wrap:wrap">'+adaptiveBtn+'<button class="bt bp" onclick="openWritingCentre()">Write Something Else</button><button class="bt bg" onclick="go(\'english\')">Back to English</button></div>';
