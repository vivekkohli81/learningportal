function openWritingCentre(){
  let SC=document.getElementById('SC');
  let s=S.english.writing;
  let wType=window._writingType||null;
  if(wType){selectWritingType(wType);return;}
  let typeCards=Object.entries(WRITING_TYPES).map(function(entry){
    let key=entry[0],wt=entry[1];
    return '<div class="sc" onclick="selectWritingType(\''+key+'\')" style="border-left:4px solid '+wt.color+'"><div style="font-size:28px;margin-bottom:8px">'+wt.icon+'</div><h3>'+wt.name+'</h3><div class="ds">'+wt.desc+'</div></div>';
  }).join('');
  SC.innerHTML='<div class="cd"><h2>Writing Centre</h2><div class="ds">Choose a type of writing. After you write, AI will read your work and give you detailed feedback like a teacher.</div><div style="margin-top:8px">'+lvBadge(s.lv)+'</div></div><div class="sg">'+typeCards+'</div><div style="margin-top:16px"><button class="bt" style="background:var(--b)" onclick="go(\'english\')">Back to English</button></div>';
