  let tipsHtml=(fb.improvement_tips||[]).map(function(t,i){return '<div style="padding:10px 12px;background:var(--pl);border-radius:8px;margin-bottom:8px;font-size:14px"><strong>Tip '+(i+1)+':</strong> '+t+'</div>';}).join('');
