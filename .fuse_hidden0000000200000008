function getActiveKey(){
  if(DB.settings.provider==='gemini') return DB.settings.geminiKey;
  return DB.settings.key;
}

function hasAIKey(){
  return getActiveKey() && getActiveKey().length>5;
}

async function callAI(prompt,maxTokens){
  if(!hasAIKey()) throw new Error('No API key set. Ask your parent/teacher to add an API key in Admin Dashboard > AI Settings.');
  if(DB.settings.provider==='gemini'){
    return await callGemini(prompt,maxTokens);
  } else {
    return await callClaude(prompt,maxTokens);
  }
}

async function callClaude(prompt,maxTokens){
  let res=await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{'Content-Type':'application/json','x-api-key':DB.settings.key,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
    body:JSON.stringify({model:DB.settings.model,max_tokens:maxTokens||1500,messages:[{role:'user',content:prompt}]})
  });
  let data=await res.json();
  if(data.error) throw new Error('Claude error: '+data.error.message);
  return data.content[0].text;
}

async function callGemini(prompt,maxTokens){
  let modelsToTry=[DB.settings.model||'gemini-2.0-flash','gemini-2.5-flash-preview-05-20','gemini-1.5-flash','gemini-2.0-flash','gemini-1.5-pro'];
  let seen=new Set();
  let lastErr='';
  for(let model of modelsToTry){
    if(seen.has(model))continue;
    seen.add(model);
    try{
      let url='https://generativelanguage.googleapis.com/v1beta/models/'+model+':generateContent?key='+DB.settings.geminiKey;
      let res=await fetch(url,{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({contents:[{parts:[{text:prompt}]}],generationConfig:{maxOutputTokens:maxTokens||1500}})
      });
      let data=await res.json();
      if(data.error){
        let msg=data.error.message||JSON.stringify(data.error);
        if(msg.includes('quota')||msg.includes('rate')||msg.includes('limit')||msg.includes('429')){
          lastErr=msg;
          continue;
        }
        throw new Error('Gemini error ('+model+'): '+msg);
      }
      if(!data.candidates||!data.candidates[0]) throw new Error('Gemini returned no response ('+model+').');
      return data.candidates[0].content.parts[0].text;
    }catch(e){
      if(e.message&&(e.message.includes('quota')||e.message.includes('rate')||e.message.includes('limit'))){
        lastErr=e.message;
        continue;
      }
      throw e;
    }
  }
  throw new Error('All Gemini models are currently over their free quota. This usually resets within a few minutes. Please wait a bit and try again, or switch to Claude in AI Settings. Last error: '+lastErr);
}

