async function submitSYW(){
  var answer=document.getElementById('sywAnswer').value.trim();
  if(!answer||answer.length<5){alert('Please write your working and answer before submitting.');return;}
  var btn=document.getElementById('sywSubmitBtn');
  btn.disabled=true;btn.textContent='AI is marking...';
  var q=CQ.sywQuestion;
  var kidName=currentUser&&currentUser.kid?currentUser.kid.name:'Student';
  var asdMode=currentUser&&currentUser.kid&&currentUser.kid.asd;
  
  var prompt='You are a friendly, encouraging maths/English teacher marking a student\'s work. '
    +'The student is '+kidName+', age '+(currentUser.kid?currentUser.kid.age:11)+', Year '+(currentUser.kid?currentUser.kid.year:6)+'. '
    +(asdMode?'The student learns best with clear, structured, and encouraging instructions. Use simple language. ':'')
    +'\n\nQUESTION (worth '+q.marks+' marks):\n'+q.q
    +'\n\nCORRECT ANSWER:\n'+q.answer
    +'\n\nSTUDENT\'S ANSWER:\n'+answer
    +'\n\nPlease respond in this EXACT JSON format (no other text):\n'
    +'{"marks_given":NUMBER,"out_of":'+q.marks+',"correct":BOOLEAN,"method_correct":BOOLEAN,'
    +'"feedback":"Your detailed feedback here - what they did well and what to improve",'
    +'"correction":"If wrong, show the correct working step by step here, otherwise empty string",'
    +'"encouragement":"A short encouraging message"}';
  
  try{
    var result=await callAI(prompt,1200);
    // Parse JSON from response
    var jsonStr=result;
    var jsonMatch=result.match(/\{[\s\S]*\}/);
    if(jsonMatch) jsonStr=jsonMatch[0];
    var fb=JSON.parse(jsonStr);
    
    // Update scores
    var s=S[CQ.subject][CQ.topic];
    if(fb.correct){s.ok++;CQ.score=1;}else{s.no++;}
    S.total++;
    S.done.push({date:new Date().toDateString(),subject:CQ.subject,topic:CQ.topic,score:fb.marks_given+'/'+fb.out_of,mode:'syw'});
    markActive();sv();
    
    var pct=Math.round(fb.marks_given/fb.out_of*100);
    var color=pct>=80?'var(--g)':pct>=50?'var(--w)':'var(--e)';
    
    var html='<div style="border:2px solid '+color+';border-radius:var(--r);overflow:hidden">';
    html+='<div style="background:'+color+';color:#fff;padding:12px 16px;display:flex;justify-content:space-between;align-items:center">';
    html+='<strong style="font-size:16px">'+fb.encouragement+'</strong>';
    html+='<span style="font-size:20px;font-weight:700">'+fb.marks_given+'/'+fb.out_of+'</span></div>';
    html+='<div style="padding:16px">';
    html+='<div style="margin-bottom:12px"><strong>Method:</strong> '+(fb.method_correct?'<span style="color:var(--g)">Correct approach</span>':'<span style="color:var(--e)">Needs improvement</span>')+'</div>';
    html+='<div style="margin-bottom:12px"><strong>Feedback:</strong> '+fb.feedback+'</div>';
    if(fb.correction){
      html+='<div style="padding:12px;background:#fef2f2;border-radius:var(--r);margin-bottom:12px"><strong>Correct working:</strong><br>'+fb.correction.replace(/\n/g,'<br>')+'</div>';
    }
    html+='</div></div>';
    html+='<div style="margin-top:16px;display:flex;gap:8px;flex-wrap:wrap">';
    html+='<button class="bt bp" onclick="startShowYourWork(\''+CQ.subject+'\',\''+CQ.topic+'\')">Try Another</button>';
    if(hasAIKey()){html+='<button class="bt" style="background:var(--v);color:#fff" onclick="generateSYW(\''+CQ.subject+'\',\''+CQ.topic+'\')">AI Generated Problem</button>';}
    html+='<button class="bt" style="background:var(--b)" onclick="go(\''+CQ.subject+'\')">Back to '+((CQ.subject==='english')?'English':'Maths')+'</button>';
    html+='</div>';
    
    document.getElementById('sywFeedback').innerHTML=html;
    btn.style.display='none';
  }catch(e){
    btn.disabled=false;btn.textContent='Submit for AI Marking';
    document.getElementById('sywFeedback').innerHTML='<div class="fb no">Error: '+e.message+'. Please try again.</div>';
  }
}

async function generateSYW(subj,topic){
  if(!hasAIKey()){alert('AI features require an API key. Set one up in AI Settings.');return;}
  var SC=document.getElementById('SC');
  var s=S[subj][topic];
  var kidAge=currentUser&&currentUser.kid?currentUser.kid.age:11;
  var kidYear=currentUser&&currentUser.kid?currentUser.kid.year:6;
  var asd=currentUser&&currentUser.kid&&currentUser.kid.asd;
  var lvNames={1:'Year 5-6',2:'Year 6-7',3:'Year 7-8',4:'Year 9-10',5:'Year 10-11'};
  var topicNames={geometry:'Geometry (shapes, area, perimeter, angles, volume)',problemSolving:'Word Problems (multi-step, money, time, ratios)',number:'Number (fractions, decimals, percentages, algebra)',punctuation:'Punctuation and Grammar',reading:'Reading Comprehension',writing:'Writing',biology:'Biology (cells, body systems, ecosystems, genetics)',chemistry:'Chemistry (materials, reactions, atoms, periodic table)',physics:'Physics (forces, energy, electricity, waves)',earthSpace:'Earth and Space (solar system, rocks, weather, climate)',numberAlgebra:'Number & Algebra (IB MYP: whole numbers, exponents, order of operations, algebraic expressions)',fractionDecimal:'Fractions & Decimals (IB MYP: operations, conversions, ordering)',percentage:'Percentages (IB MYP: conversions, increase/decrease, profit/loss)',equations:'Equations (IB MYP: solving, inverse operations, word problems)',geometry7:'Geometry (IB MYP: polygons, angles, transformations, coordinates)',measurement:'Measurement (IB MYP: area, volume, capacity, mass)',statistics:'Statistics (IB MYP: data, stem-leaf, mean/median/mode)',probability:'Probability (IB MYP: theoretical, experimental, sample space)'};

  SC.innerHTML='<div class="cd" style="text-align:center;padding:40px"><div class="ld"></div><div style="margin-top:16px">AI is creating a problem for you...</div></div>';

  var prompt='Create ONE challenging show-your-work problem for a '+kidAge+'-year-old student in Year '+kidYear+'. '
    +(asd?'Student learns best with clear, structured instructions. ':'')
    +'Topic: '+subj+' > '+(topicNames[topic]||topic)+'. Difficulty: '+lvNames[s.lv]+'. '
    +'The problem should require multi-step working. '
    +'Respond in EXACT JSON format (no other text): '
    +'{"q":"The full question text","hint":"A helpful hint","answer":"The full correct working and answer","marks":NUMBER_3_to_5}';
  
  try{
    var result=await callAI(prompt,800);
    var jsonMatch=result.match(/\{[\s\S]*\}/);
    if(!jsonMatch) throw new Error('Invalid AI response');
    var q=JSON.parse(jsonMatch[0]);
    q.id='ai_syw_'+Date.now();
    CQ={active:true,subject:subj,topic:topic,mode:'syw',sywQuestion:q,idx:0,score:0,questions:[],answers:[]};
    renderSYWQuestion();
  }catch(e){
    SC.innerHTML='<div class="cd"><div class="fb no">Failed to generate question: '+e.message+'</div><button class="bt bp" onclick="go(\''+subj+'\')">Go Back</button></div>';
  }
}

