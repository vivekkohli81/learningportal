    let d=(fb.scores||{})[cat];if(!d)return '';
    let c=d.score>=75?'var(--g)':d.score>=50?'var(--w)':'var(--e)';
    return '<div style="margin-bottom:16px"><div style="display:flex;justify-content:space-between;align-items:center"><strong>'+catLabels[cat]+'</strong><span style="font-weight:700;color:'+c+'">'+d.score+'/100</span></div><div class="pb"><div class="pf" style="width:'+d.score+'%;background:'+c+'"></div></div><div style="font-size:13px;color:var(--t2)">'+d.comment+'</div></div>';
  }).join('');
  let strengthsHtml=(fb.strengths||[]).map(function(s){return '<div style="padding:8px 12px;background:var(--gl);border-radius:8px;margin-bottom:8px;font-size:14px">\u2713 '+s+'</div>';}).join('');
