function renderWritingScreen(){
  let SC=document.getElementById('SC');
  let p=CQ.prompt;
  let wt=WRITING_TYPES[CQ.writingType];
  let steps=p.sc.map(function(step){return '<div class="wsp"><div class="wsl">'+step.l+'</div><div style="font-size:14px;color:var(--t2)">'+step.h+'</div></div>';}).join('');
  SC.innerHTML='<div class="cd"><div style="display:flex;align-items:center;gap:12px;margin-bottom:8px"><span style="font-size:24px">'+wt.icon+'</span><div><div class="qn">'+wt.name+'</div><h2>'+p.title+'</h2></div></div><div class="ds" style="font-size:15px">'+p.inst+'</div></div><div class="cd"><h3>Follow these steps to plan your writing:</h3><div class="wsc">'+steps+'</div></div><div class="cd"><h3>Write your '+wt.name.toLowerCase()+' here:</h3><textarea class="wr" id="wrText" style="min-height:250px" placeholder="Start writing here... Follow the steps above to help you."></textarea><div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px"><div style="font-size:12px;color:var(--t2)" id="wCount">0 words | 0 sentences | Aim for at least '+(p.min||30)+' words</div></div><div style="margin-top:16px;display:flex;gap:8px;flex-wrap:wrap"><button class="bt bp" onclick="submitWritingToAI()">Submit for AI Feedback</button><button class="bt" style="background:var(--g);color:#fff" onclick="submitWritingBasic()">Quick Check (no AI)</button><button class="bt" style="background:var(--b)" onclick="window._writingType=\''+CQ.writingType+'\';selectWritingType(\''+CQ.writingType+'\')">Cancel</button></div></div>';
  document.getElementById('wrText').addEventListener('input',function(){
    let t=this.value.trim();
    let words=t?t.split(/\s+/).length:0;
    let sentences=(t.match(/[.!?]+/g)||[]).length;
    document.getElementById('wCount').textContent=words+' words | '+sentences+' sentences | Aim for at least '+(CQ.prompt.min||30)+' words';
  });
}

function submitWritingBasic(){
  let text=document.getElementById('wrText').value.trim();
  if(!text||text.split(/\s+/).length<5){alert('Please write at least 5 words before submitting.');return;}
  let p=CQ.prompt;let s=S.english.writing;
  let words=text.split(/\s+/).length;
  let sentences=(text.match(/[.!?]+/g)||[]).length;
  let startsCapital=/^[A-Z]/.test(text);
  let score=0,feedback=[];
  let minW=p.min||30;
  if(words>=minW){score+=25;feedback.push({ok:true,msg:'Good length! You wrote '+words+' words.'});}
  else{feedback.push({ok:false,msg:'Try to write more. You wrote '+words+' words. Aim for at least '+minW+'.'});}
  if(sentences>=3){score+=25;feedback.push({ok:true,msg:'Good use of sentence endings ('+sentences+' found).'});}
  else{feedback.push({ok:false,msg:'Remember to end every sentence with a full stop, question mark, or exclamation mark.'});}
  if(startsCapital){score+=25;feedback.push({ok:true,msg:'Your writing starts with a capital letter.'});}
  else{feedback.push({ok:false,msg:'Always start your writing with a capital letter.'});}
  if(text.includes('\n')||words>40){score+=25;feedback.push({ok:true,msg:'Good structure!'});}
  else{feedback.push({ok:false,msg:'Try to develop your ideas more. Use paragraphs for longer writing.'});}
  if(!s.sn.includes(p.id))s.sn.push(p.id);
  s.ok+=Math.round(score/25);s.no+=(4-Math.round(score/25));
  s.h.push({date:new Date().toDateString(),score:score,total:100,pct:score});
  S.total++;S.done.push({date:new Date().toDateString(),subject:'english',topic:'writing',score:score+'/100'});
  S.wr.push({date:new Date().toDateString(),title:p.title,type:CQ.writingType,text:text,score:score,feedback:feedback,mode:'basic'});
  if(score>=80&&s.lv<5)s.lv++;else if(score<40&&s.lv>1)s.lv--;
  markActive();sv();
  let fbHtml=feedback.map(function(f){return '<div class="fb '+(f.ok?'ok':'no')+'" style="margin-bottom:8px">'+(f.ok?'\u2713':'\u2717')+' '+f.msg+'</div>';}).join('');
  let scoreColor=score>=75?'var(--g)':score>=50?'var(--w)':'var(--e)';
  let SC=document.getElementById('SC');
  SC.innerHTML='<div class="cd" style="text-align:center"><h2>Quick Check Complete</h2><div style="font-size:48px;font-weight:700;color:'+scoreColor+';margin:16px 0">'+score+'/100</div><div class="ds">For detailed teacher-style feedback, use "Submit for AI Feedback" next time.</div></div><div class="cd"><h3>Basic Feedback:</h3>'+fbHtml+'</div><div class="cd"><h3>What you wrote:</h3><div style="background:#f8fafc;padding:16px;border-radius:var(--r);border:1px solid var(--b);white-space:pre-wrap;font-size:14px;line-height:1.8">'+text.replace(/</g,'&lt;')+'</div></div><div style="margin-top:16px;display:flex;gap:8px"><button class="bt bp" onclick="openWritingCentre()">Write Something Else</button><button class="bt bg" onclick="go(\'english\')">Back to English</button></div>';
  CQ.active=false;updateHeader();
}

async function submitWritingToAI(){
  let text=document.getElementById('wrText').value.trim();
  if(!text||text.split(/\s+/).length<5){alert('Please write at least 5 words before submitting.');return;}
  if(!hasAIKey()){alert('To get AI feedback, please set your API key in the Parent Dashboard (Settings tab). You can also use Quick Check for basic feedback.');return;}
  let p=CQ.prompt;let wt=WRITING_TYPES[CQ.writingType];let s=S.english.writing;
  let lvNames={1:'beginner (Year 5-6, age 10-11)',2:'intermediate (Year 7-8, age 11-13)',3:'advanced (Year 8-9, age 13-14)'};
  let SC=document.getElementById('SC');
  SC.innerHTML='<div class="cd" style="text-align:center"><h2>AI Teacher is reading your writing...</h2><div class="ds">Using '+(DB.settings.provider==='gemini'?'Google Gemini':'Claude')+' ('+DB.settings.model+'). Checking grammar, structure, ideas, and vocabulary.</div><div class="pb"><div class="pf" style="width:60%"></div></div><div style="margin-top:16px;color:var(--t2);font-size:13px">This usually takes 10-20 seconds.</div></div>';
  let aiPrompt='You are a supportive English teacher for a '+lvNames[s.lv]+' student who learns best with clear, direct language. Use explicit instructions. Avoid figurative language or idioms.\n\nThe student wrote a '+wt.name.toLowerCase()+' for this assignment:\nTitle: "'+p.title+'"\nInstructions: "'+p.inst+'"\n\nStudent wrote:\n---\n'+text+'\n---\n\nAnalyse and return ONLY a JSON object:\n{"overall_score":<0-100>,"scores":{"grammar":{"score":<0-100>,"comment":"<1-2 sentences>"},"spelling":{"score":<0-100>,"comment":"<1-2 sentences>"},"structure":{"score":<0-100>,"comment":"<1-2 sentences>"},"ideas":{"score":<0-100>,"comment":"<1-2 sentences>"},"vocabulary":{"score":<0-100>,"comment":"<1-2 sentences>"}},"strengths":["<specific strength>","<another>"],"errors":[{"original":"<exact text>","corrected":"<fixed version>","rule":"<rule explained simply>"}],"corrected_version":"<full corrected text>","improvement_tips":["<tip 1>","<tip 2>","<tip 3>"],"next_focus":"<one specific area to practise next>","encouragement":"<warm encouraging sentence>"}';
  try{
    let respText=await callAI(aiPrompt,3000);
    let match=respText.match(/\{[\s\S]*\}/);
    if(!match)throw new Error('Could not parse AI response.');
    let fb=JSON.parse(match[0]);
    if(!s.sn.includes(p.id))s.sn.push(p.id);
    let sc=fb.overall_score||50;
    s.ok+=Math.round(sc/20);s.no+=(5-Math.round(sc/20));
    s.h.push({date:new Date().toDateString(),score:sc,total:100,pct:sc});
    S.total++;S.done.push({date:new Date().toDateString(),subject:'english',topic:'writing',score:sc+'/100'});
    S.wr.push({date:new Date().toDateString(),title:p.title,type:CQ.writingType,text:text,score:sc,aiFeedback:fb,mode:'ai'});
    if(sc>=80&&s.lv<5)s.lv++;else if(sc<40&&s.lv>1)s.lv--;
    markActive();sv();
    renderAIFeedback(text,fb,CQ.writingType);
  }catch(e){
    SC.innerHTML='<div class="cd"><h2>Could not get AI feedback</h2><div class="ds" style="color:var(--e)">'+e.message+'</div><div style="margin-top:16px"><button class="bt bp" onclick="renderWritingScreen()">Try Again</button><button class="bt" style="background:var(--b);margin-left:8px" onclick="go(\'english\')">Back</button></div></div>';
  }
}

function renderAIFeedback(originalText,fb,writingType){
  let SC=document.getElementById('SC');
  let scoreColor=fb.overall_score>=75?'var(--g)':fb.overall_score>=50?'var(--w)':'var(--e)';
