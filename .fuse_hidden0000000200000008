// === NAVIGATION ===
function go(screen){
  curScreen=screen;
  document.querySelectorAll('.nb').forEach((b,i)=>{
    const map=['home','english','maths','ib7','science','resources','writing','settings'];
    b.classList.toggle('on',map[i]===screen);
  });
  const SC=document.getElementById('SC');
  switch(screen){
    case 'home': renderHome(SC); break;
    case 'english': renderEnglish(SC); break;
    case 'maths': renderMaths(SC); break;
    case 'ib7': renderIB7(SC); break;
    case 'science': renderScience(SC); break;
    case 'resources': renderResources(SC); break;
    case 'writing': openWritingCentre(); break;
    case 'settings': renderStudentSettings(SC); break;
    default: renderHome(SC);
  }
  updateHeader();
}

function updateHeader(){
  document.getElementById('s1').textContent='Streak: '+S.streak+' day'+(S.streak!==1?'s':'');
  document.getElementById('s2').textContent='Done: '+S.total;
  let today=S.done.filter(d=>d.date===new Date().toDateString()).length;
  document.getElementById('s3').textContent='Today: '+today;
}

function lvBadge(lv){
  const names=['','Beginner','Intermediate','Advanced','Expert','Master'];
  const cls=['','b1','b2','b3','b3','b3'];
  return `<span class="badge ${cls[lv]}">${names[lv]} (Level ${lv})</span>`;
}

function pctBar(ok,no){
  let t=ok+no;
  let p=t>0?Math.round(ok/t*100):0;
  return `<div class="pb"><div class="pf" style="width:${p}%"></div></div><div style="font-size:12px;color:var(--t2)">${p}% correct (${ok}/${t})</div>`;
}

