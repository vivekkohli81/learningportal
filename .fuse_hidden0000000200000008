    SC.innerHTML='<div class="cd"><h2>Could not generate prompt</h2><div class="ds" style="color:var(--e)">'+e.message+'</div><button class="bt bp" onclick="openWritingCentre()" style="margin-top:16px">Back</button></div>';
  }
}

async function generateAIWritingPrompt(typeKey){
  if(!hasAIKey()){alert('Please set your API key in the Parent Dashboard first.');return;}
