  html+='<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:12px">';
  var topics=[
    ['wholeNumbers','Ch 1: Whole Numbers','Place value, rounding, exponents, operations','#1976D2'],
    ['numberProperties','Ch 2: Number Properties','Squares, cubes, primes, HCF, LCM, factors','#388E3C'],
    ['linesAngles','Ch 3: Lines & Angles','Angle types, parallel lines, transversals','#F57C00'],
    ['numberStrategies','Ch 4: Number Strategies','BEDMAS, estimation, problem solving','#7B1FA2'],
    ['posNegNumbers','Ch 5: Positive & Negative','Integer operations, number line, real world','#C62828'],
    ['fractions','Ch 6: Fractions','Equivalent, mixed numbers, operations, reciprocals','#00838F'],
    ['decimals','Ch 7: Decimals','Place value, rounding, operations, conversions','#4E342E'],
    ['algebra','Ch 8: Algebra','Expressions, substitution, like terms, formulae','#1565C0'],
    ['percentage','Ch 9: Percentage','Conversions, finding %, increase/decrease, discount','#2E7D32'],
    ['equations','Ch 10: Equations','Solving, flowcharts, word problems, inverse operations','#AD1457'],
    ['polygons','Ch 11: Polygons','Triangles, quadrilaterals, angle sums, exterior angles','#E65100'],
    ['measurementArea','Ch 12: Measurement','Length, perimeter, area of shapes, circles','#00695C'],
    ['solids','Ch 13: Solids','3D shapes, nets, views, prisms, pyramids','#4527A0'],
    ['volumeMass','Ch 14: Volume & Mass','Volume, capacity, mass, unit conversions','#283593'],
    ['coordGeometry','Ch 15: Coordinate Geometry','Plotting, quadrants, midpoint, equations of lines','#BF360C'],
    ['ratioRates','Ch 16: Ratio & Rates','Simplifying, sharing, unit cost, scale, speed','#33691E'],
